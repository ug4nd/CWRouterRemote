{
  "ssh": {
    "host": "192.168.1.1",
    "port": 22,
    "username": "root",
    "password": "",
    "ssh_key_path": "",
    "connect_timeout": 15,
    "command_timeout": 300
  },
  "cloudflared": {
    "enabled": true,
    "install_package": true,
    "install_luci": true,
    "configure_token_service": true,
    "tunnel_token": "PASTE_CLOUDFLARE_TUNNEL_TOKEN_HERE",
    "token_path": "/etc/cloudflared/token",
    "init_script_path": "/etc/init.d/cloudflared"
  },
  "v2raya": {
    "enabled": true,
    "install_package": true,
    "install_luci": true,
    "core": "xray",
    "enable_service": true
  },
  "deploy": {
    "dry_run": false,
    "update_package_lists": true,
    "check_status_after": true,
    "public_ip_service_url": "https://api.ipify.org"
  }
}
